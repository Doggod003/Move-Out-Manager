import { Outlet, NavLink, Link, useLocation } from 'react-router-dom'
import { Home, Calendar, ListTree, Building2, BarChart3, Users, Settings, Plus, Sparkles, Search } from 'lucide-react'
import { useState } from 'react'
import Logo from '../components/Logo.jsx'
import NewPropertyModal from '../components/NewPropertyModal.jsx'
import { useStore } from '../lib/store.jsx'
import { checklistStats } from '../lib/utils.js'

export default function AppShell() {
  const [newPropOpen, setNewPropOpen] = useState(false)
  const store = useStore()
  const loc = useLocation()

  return (
    <div className="min-h-screen flex bg-ink-50">
      <Sidebar onNewProperty={() => setNewPropOpen(true)} />
      <div className="flex-1 flex flex-col min-w-0">
        <Topbar onNewProperty={() => setNewPropOpen(true)} />
        <main className="flex-1 overflow-y-auto">
          <div className="max-w-7xl mx-auto px-6 py-8">
            <Outlet />
          </div>
        </main>
      </div>
      {newPropOpen && <NewPropertyModal onClose={() => setNewPropOpen(false)} />}
    </div>
  )
}

function Sidebar({ onNewProperty }) {
  const { properties } = useStore()
  return (
    <aside className="w-64 bg-white border-r border-ink-200 flex-col hidden lg:flex">
      <div className="px-5 h-16 border-b border-ink-200 flex items-center">
        <Link to="/" className="hover:opacity-80 transition-opacity"><Logo size={28} /></Link>
      </div>

      <button onClick={onNewProperty} className="mx-4 mt-4 btn-brand py-2.5 text-sm">
        <Plus className="w-4 h-4" /> New property
      </button>

      <nav className="px-2 py-4 space-y-0.5">
        <SidebarLink to="/app" end icon={Home} label="Dashboard" />
        <SidebarLink to="/app/calendar" icon={Calendar} label="Calendar" />
        <SidebarLink to="/app/timeline" icon={ListTree} label="Timeline" />
        <SidebarLink to="/app/vendors" icon={Building2} label="Vendors" />
        <SidebarLink to="/app/reports" icon={BarChart3} label="Reports" />
        <SidebarLink to="/app/team" icon={Users} label="Team" />
      </nav>

      {properties.length > 0 && (
        <div className="px-3 mt-4 flex-1 min-h-0 flex flex-col">
          <div className="text-xs font-semibold uppercase tracking-wider text-ink-400 px-2 mb-2">Properties</div>
          <div className="overflow-y-auto flex-1 space-y-0.5 pb-4">
            {properties.map(p => {
              const s = checklistStats(p)
              return (
                <NavLink key={p.id} to={`/app/property/${p.id}`}
                  className={({ isActive }) => `flex items-center gap-2.5 px-3 py-1.5 rounded-lg text-sm transition-colors ${isActive ? 'bg-ink-100 text-ink-900 font-medium' : 'text-ink-600 hover:bg-ink-50'}`}>
                  <span className="text-base flex-shrink-0">{p.themeIcon}</span>
                  <span className="truncate flex-1">{p.name}</span>
                  <span className="text-[11px] font-medium text-ink-500 flex-shrink-0">{s.pct}%</span>
                </NavLink>
              )
            })}
          </div>
        </div>
      )}

      <div className="p-3 border-t border-ink-200">
        <SidebarLink to="/app/settings" icon={Settings} label="Settings" />
      </div>
    </aside>
  )
}

function SidebarLink({ to, end, icon: Icon, label }) {
  return (
    <NavLink to={to} end={end} className={({ isActive }) => `flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm transition-colors ${isActive ? 'bg-brand-50 text-brand-700 font-medium' : 'text-ink-600 hover:bg-ink-50'}`}>
      <Icon className="w-4 h-4" />{label}
    </NavLink>
  )
}

function Topbar({ onNewProperty }) {
  const { properties, team } = useStore()
  const [query, setQuery] = useState('')
  return (
    <header className="h-16 bg-white border-b border-ink-200 px-6 flex items-center justify-between sticky top-0 z-30">
      <div className="flex items-center gap-3 flex-1 max-w-md">
        <div className="relative flex-1">
          <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-ink-400" />
          <input value={query} onChange={e => setQuery(e.target.value)} placeholder="Search properties, tasks…" className="input pl-9 h-9" />
        </div>
      </div>
      <div className="flex items-center gap-3">
        <span className="hidden sm:flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-brand-50 text-brand-700 text-xs font-medium">
          <span className="ai-dot" /> AI active
        </span>
        <button onClick={onNewProperty} className="lg:hidden btn-brand btn-sm">
          <Plus className="w-4 h-4" />
        </button>
        <div className="w-9 h-9 rounded-full bg-ink-200 flex items-center justify-center text-sm font-medium text-ink-700">
          {team[0]?.avatar || '👤'}
        </div>
      </div>
    </header>
  )
}
